# 本仓库唯一的"机密总入口"。
#
# 用法：
#   1. cp .env.local.example .env.local
#   2. 在 .env.local 里填真实值（.env.local 已被 .gitignore 排除，不会入库）
#   3. 跑 bash k8s/setup-litellm.sh —— 脚本 source 此文件，渲染 K8s Secret
#
# 维护原则：
#   - 真实值禁止 commit；模板（本文件）的值必须保持空字符串
#   - 新增 key 时同步更新 k8s/setup-litellm.sh 的 --from-literal 列表
#   - 文件命名遵循 .env.* 模式，自动被 .gitignore 拦截

# ── LiteLLM 网关本身 ────────────────────────────────────────────────
LITELLM_MASTER_KEY=          # 网关访问凭据（agent 用），自定义即可，建议 sk-<random>
LITELLM_SALT_KEY=            # LiteLLM DB 加密盐，自定义即可

# ── 上游模型供应商 ──────────────────────────────────────────────────
DEEPSEEK_API_KEY=            # DeepSeek: https://platform.deepseek.com/api_keys
ARK_API_KEY=                 # 火山方舟（glm/kimi 路由依赖）: https://console.volcengine.com/ark
DASHSCOPE_API_KEY=           # 阿里通义千问
DASHSCOPE_APPS_API_KEY=      # 阿里百炼应用 key（默认回退到 DASHSCOPE_API_KEY）
OPENAI_API_KEY=              # OpenAI 官方
ANTHROPIC_API_KEY=           # Anthropic 官方

# ── Job-Agent 用的 GitHub 凭据 ─────────────────────────────────────
GIT_TOKEN=                   # GitHub PAT，job-agent 容器 git push 用；scope: repo
