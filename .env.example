# Claude Pipeline 环境变量配置
# 复制为 .env 并填入真实值

# Anthropic API Key（必需）
ANTHROPIC_API_KEY=sk-ant-...

# 也可以使用 ANTHROPIC_AUTH_TOKEN 兼容旧版本（两者取一即可）
# ANTHROPIC_AUTH_TOKEN=sk-ant-...

# 自定义 API Base URL（可选）
# 留空则使用官方默认 https://api.anthropic.com
# 使用代理或私有部署时填写，如: https://your-proxy.example.com
# ANTHROPIC_BASE_URL=https://your-proxy.example.com

# 覆盖 config.yaml 中的模型配置（可选）
# ANTHROPIC_MODEL=claude-opus-4-5-20251001

# GitHub Personal Access Token（需要 repo + workflow 权限）
GIT_TOKEN=ghp_...

# 可选：同上（两者取一即可）
# GITHUB_TOKEN=ghp_...
