# claude-pipeline-base
#
# 预装所有重型依赖，避免每次任务运行时重复下载：
#   - 构建工具链：gcc / clang / cmake / pkg-config / build-essential
#   - 常用系统库：openssl / sqlite3 / libxml2 / zlib 等
#   - Rust stable（pipeline 用户 $HOME/.cargo）
#   - Node.js 20 + claude CLI
#   - Python 3.11
#   - GitHub CLI（gh）
#   - git / curl / sudo

FROM ubuntu:22.04

ENV DEBIAN_FRONTEND=noninteractive
ENV PYTHONUNBUFFERED=1
ENV NODE_VERSION=20

SHELL ["/bin/bash", "-o", "pipefail", "-c"]

# ── 1. 系统基础包 + 构建工具链 ──────────────────────────────────────
RUN apt-get update && apt-get install -y --no-install-recommends \
    # 基础工具
    curl \
    git \
    sudo \
    ca-certificates \
    gnupg \
    apt-transport-https \
    # 构建工具链
    build-essential \
    gcc \
    g++ \
    clang \
    cmake \
    pkg-config \
    # Python
    python3.11 \
    python3.11-venv \
    python3-pip \
    # 常用 Rust/C 项目系统库
    libssl-dev \
    libsqlite3-dev \
    libxml2-dev \
    zlib1g-dev \
    libbz2-dev \
    libffi-dev \
    && rm -rf /var/lib/apt/lists/*

# ── 2. GitHub CLI ────────────────────────────────────────────────────
RUN curl -fsSL https://cli.github.com/packages/githubcli-archive-keyring.gpg \
        | dd of=/usr/share/keyrings/githubcli-archive-keyring.gpg && \
    chmod go+r /usr/share/keyrings/githubcli-archive-keyring.gpg && \
    echo "deb [arch=$(dpkg --print-architecture) signed-by=/usr/share/keyrings/githubcli-archive-keyring.gpg] https://cli.github.com/packages stable main" \
        | tee /etc/apt/sources.list.d/github-cli.list > /dev/null && \
    apt-get update && apt-get install -y --no-install-recommends gh && \
    rm -rf /var/lib/apt/lists/*

# ── 3. Python 默认版本 ───────────────────────────────────────────────
RUN update-alternatives --install /usr/bin/python3 python3 /usr/bin/python3.11 1 && \
    update-alternatives --install /usr/bin/python python /usr/bin/python3.11 1

# ── 4. Node.js 20 ───────────────────────────────────────────────────
RUN curl -fsSL https://deb.nodesource.com/setup_${NODE_VERSION}.x | bash - && \
    apt-get install -y --no-install-recommends nodejs && \
    rm -rf /var/lib/apt/lists/*

# ── 5. claude CLI ────────────────────────────────────────────────────
# hadolint ignore=DL3016
RUN npm install -g @anthropic-ai/claude-code

# ── 6. 创建 pipeline 用户（claude CLI 拒绝以 root 运行）───────────
RUN useradd -m -s /bin/bash pipeline && \
    echo "pipeline ALL=(ALL) NOPASSWD:ALL" > /etc/sudoers.d/pipeline && \
    mkdir -p /workspace /agent && \
    chown -R pipeline:pipeline /workspace /agent

# ── 7. 以 pipeline 用户安装 Rust stable ─────────────────────────────
USER pipeline
RUN curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs \
        | sh -s -- -y --default-toolchain stable --profile minimal && \
    /home/pipeline/.cargo/bin/rustup component add clippy rustfmt

# 将 cargo bin 加入 PATH，对所有后续 RUN 和容器运行时均生效
ENV PATH="/home/pipeline/.cargo/bin:${PATH}"

WORKDIR /workspace
