# 使用方法:
#   cp k8s/secret.yaml.example k8s/secret.yaml
#   编辑填入 base64 编码值后: kubectl apply -f k8s/secret.yaml
#
# 获取 base64 编码值:
#   echo -n 'sk-ant-...' | base64
#   echo -n 'ghp_...' | base64
apiVersion: v1
kind: Secret
metadata:
  name: claude-pipeline-secrets
  namespace: claude-pipeline
type: Opaque
data:
  ANTHROPIC_API_KEY: ""   # echo -n 'sk-ant-...' | base64
  GIT_TOKEN: ""           # echo -n 'ghp_...' | base64
