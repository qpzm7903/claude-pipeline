# LiteLLM 网关密钥模板。
#
# 使用：
#   1. cp k8s/litellm-secret.yaml.example k8s/litellm-secret.yaml
#   2. 填入真实 key（litellm-secret.yaml 已被 .gitignore 忽略，不会入库）
#   3. kubectl apply -f k8s/litellm.yaml -f k8s/litellm-secret.yaml
#
# 真实值禁止 commit。
---
apiVersion: v1
kind: Secret
metadata:
  name: litellm-secrets
  namespace: litellm
type: Opaque
stringData:
  LITELLM_MASTER_KEY: ""        # 网关访问凭据，给 agent 用，自定义即可
  LITELLM_SALT_KEY: ""          # LiteLLM 数据库加密盐，自定义即可
  DEEPSEEK_API_KEY: ""          # DeepSeek 控制台获取
  DASHSCOPE_APPS_API_KEY: ""    # 阿里百炼应用 key
  DASHSCOPE_API_KEY: ""         # 通义千问 key
  OPENAI_API_KEY: ""            # OpenAI 官方 key
  ANTHROPIC_API_KEY: ""         # Anthropic 官方 key
  ARK_API_KEY: ""               # 火山方舟 key（glm/kimi 路由依赖）
